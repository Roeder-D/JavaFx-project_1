<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.Region?>
<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="de.srh_2551.cinema_reservations.controller.ReservationController">
 <top>
     <HBox alignment="CENTER_LEFT" spacing="15.0"
           style="-fx-padding: 10px; -fx-border-color: #cccccc; -fx-border-width: 0 0 1 0;"
           BorderPane.alignment="CENTER">
         <ComboBox fx:id="hallComboBox" prefWidth="200.0" promptText="Saalauswahl"/>

         <Button fx:id="switchBasketBtn" mnemonicParsing="false" text="Warenkorb"/>

     </HBox>
 </top>
 <center>
     <StackPane BorderPane.alignment="CENTER">
         <VBox fx:id="defaultView" alignment="CENTER" prefHeight="200.0" prefWidth="100.0" visible="false"
               StackPane.alignment="CENTER">
             <Label alignment="CENTER" text="Please select a cinema hall to beginn.">
                 <font>
                     <Font size="18.0"/>
                 </font>
             </Label>
         </VBox>
         <ScrollPane fx:id="seatScrollPane" visible="false" fitToWidth="true" fitToHeight="true" pannable="true"
                     StackPane.alignment="CENTER"
                     style="-fx-background-color: transparent; -fx-background-insets: 0; -fx-padding: 0;">
             <VBox fx:id="seatContainer" alignment="CENTER" spacing="10.0">
                 <padding>
                     <Insets top="20.0" right="65.0" bottom="20.0" left="40.0"/>
                 </padding>
             </VBox>
         </ScrollPane>
         <BorderPane fx:id="basketView" prefHeight="200.0" prefWidth="200.0" visible="false">
             <top>
                 <Label text="Warenkorb" BorderPane.alignment="CENTER">
                  <BorderPane.margin>
                      <Insets bottom="10.0" top="10.0"/>
                  </BorderPane.margin>
                  <font>
                      <Font size="18.0"/>
                  </font>
                 </Label>
             </top>
             <bottom>
                 <HBox alignment="CENTER_RIGHT" spacing="20.0" BorderPane.alignment="CENTER">
                     <BorderPane.margin>
                         <Insets bottom="20.0" left="20.0" right="20.0" top="15.0"/>
                     </BorderPane.margin>

                     <ComboBox fx:id="discountComboBox" promptText="Rabatt wählen" prefWidth="170.0"/>

                     <Label fx:id="totalPriceLabel" text="Total Price: 0.00€">
                         <font>
                             <Font name="System Bold" size="18.0"/>
                         </font>
                     </Label>

                     <Region HBox.hgrow="ALWAYS" />

                     <ButtonBar>
                         <buttons>
                             <Button mnemonicParsing="false" onAction="#handleCancelBtnClick"
                                     text="Cancel"/>
                             <Button mnemonicParsing="false" onAction="#handleConfirmOrderClick"
                                     style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;"
                                     text="Confirm Order"/>
                         </buttons>
                     </ButtonBar>
                 </HBox>
             </bottom>
             <center>
                 <ListView fx:id="basketSeatList" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
                  <BorderPane.margin>
                      <Insets left="20.0" right="20.0"/>
                  </BorderPane.margin>
                 </ListView>
             </center>
         </BorderPane>
     </StackPane>
 </center>
</BorderPane>
